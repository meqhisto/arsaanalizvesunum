{
  "name": "arsa-analiz-frontend",
  "version": "1.1.4",
  "description": "Modern API-driven frontend for Arsa Analiz ve Sunum Platformu",
  "main": "webpack.config.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "frontend:dev": "webpack serve --config frontend.webpack.config.js --mode development",
    "frontend:build": "webpack --config frontend.webpack.config.js --mode production",
    "lint": "eslint static/js/**/*.js frontend/src/**/*.js",
    "format": "prettier --write static/js/**/*.js static/css/**/*.css frontend/src/**/*.js frontend/src/**/*.css"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "axios": "^1.6.0",
    "bootstrap": "^5.3.6",
    "chart.js": "^4.4.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.54.0",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.32",
    "postcss-loader": "^7.3.3",
    "prettier": "^3.1.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.4.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
